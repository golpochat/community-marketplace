PORT=4000
NODE_ENV=development
LOG_LEVEL=debug
BULLMQ_MODE=both

CORS_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://cm:cm_dev_password@localhost:5434/community_marketplace

JWT_SECRET=dev-jwt-secret-change-in-production

# Stripe — leave empty for local mock payments (no real Stripe Connect required).
# Set sk_test_... only after enabling Connect at https://dashboard.stripe.com/test/connect
STRIPE_SECRET_KEY=

STRIPE_WEBHOOK_SECRET=

# destination (default) — split at charge time. separate — platform collects, settle via POST /seller/settle-order
STRIPE_CONNECT_CHARGE_MODEL=destination

OPENAI_API_KEY=

OPENAI_EMBEDDING_MODEL=text-embedding-3-small

PLATFORM_FEE_PERCENT=10

MAX_DAILY_PAYMENTS_PER_USER=10

MEILISEARCH_HOST=http://localhost:7700

MEILISEARCH_API_KEY=dev-master-key

REDIS_URL=redis://localhost:6380
# Host API with Docker infra: Redis is mapped to 6380 (see infra/docker/docker-compose.dev.yml).
# Use redis://localhost:6379 only if Redis runs natively on the default port.

FCM_PROJECT_ID=

SENDGRID_API_KEY=

EMAIL_FROM=noreply@community.market
EMAIL_FROM_NAME=SellNearby
SUPPORT_EMAIL=support@sellnearby.ie

# Brevo transactional email (API key only — sender uses EMAIL_FROM / EMAIL_FROM_NAME above)
BREVO_API_KEY=

# Amazon SES (optional — register adapter in EmailModule when enabling send)
AWS_SES_REGION=
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=

WEB_APP_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000

# RBAC seed (development / staging only — blocked in production)

RBAC_SEED_ENABLED=true

RBAC_SEED_FORCE=false

# OTP pilot — no SMS provider; codes are returned to the web UI (and logged). Set false when live SMS is enabled.
OTP_PILOT_MODE=true

RBAC_SEED_RESET_PASSWORD=false

RBAC_SUPER_ADMIN_EMAIL=superadmin@sellnearby.ie

RBAC_SUPER_ADMIN_PASSWORD=ChangeMe!SuperAdmin1

# Cloudflare R2 (avatar / media uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=community-marketplace-dev
R2_ENDPOINT=
R2_PUBLIC_URL=https://assets.dev.community.marketplace

# Observability (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=community-marketplace-api
WORKER_HEALTH_PORT=4001

# Unified advertising system (deploy-time flags — system unpublished until enabled)
ADS_SYSTEM_ENABLED=false
ADS_PREVIEW_MODE=false
