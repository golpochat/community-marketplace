{
  "name": "@community-marketplace/api",
  "version": "0.0.0",
  "private": true,
  "description": "Community Marketplace REST API service",
  "scripts": {
    "dev": "pnpm --filter @community-marketplace/validation build && nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "ts-node -P tsconfig.scripts.json scripts/ensure-env.ts && prisma migrate dev",
    "prisma:migrate:deploy": "ts-node -P tsconfig.scripts.json scripts/ensure-env.ts && prisma migrate deploy",
    "prisma:seed": "ts-node -P tsconfig.scripts.json scripts/ensure-env.ts && prisma db seed",
    "seed:rbac": "ts-node -P tsconfig.scripts.json scripts/seed-rbac.ts",
    "migrate:seed": "ts-node -P tsconfig.scripts.json scripts/ensure-env.ts && prisma migrate dev --name init_rbac && pnpm run seed:rbac"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "ts-node -P tsconfig.scripts.json prisma/seed.ts"
  },
  "dependencies": {
    "@community-marketplace/config": "workspace:*",
    "@community-marketplace/types": "workspace:*",
    "@community-marketplace/utils": "workspace:*",
    "@community-marketplace/validation": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/websockets": "^10.4.15",
    "@prisma/client": "^6.1.0",
    "bullmq": "^5.79.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.2",
    "meilisearch": "^0.44.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "stripe": "^17.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.1.0",
    "rimraf": "^6.0.1",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
