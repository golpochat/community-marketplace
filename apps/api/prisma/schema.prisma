// Community Marketplace — Prisma schema (canonical)
// Location: apps/api/prisma/schema.prisma
//
// Commands:
//   pnpm --filter @community-marketplace/api exec prisma generate
//   pnpm --filter @community-marketplace/api exec prisma migrate dev

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ══════════════════════════════════════════════════════════════════════════════
// RBAC
// ══════════════════════════════════════════════════════════════════════════════

/// System and custom roles. `code` is unique (system codes: SUPER_ADMIN, ADMIN, SELLER, BUYER).
model Role {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(64)
  name        String
  description String?
  isSystem    Boolean      @default(true) @map("is_system")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  permissions RolePermission[]
  users       User[]
  adminInvitations AdminInvitation[]

  @@map("roles")
}

enum PermissionEffect {
  GRANT
  DENY
}
model Permission {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(80)
  name        String
  description String?
  resource    String   @db.VarChar(40)
  action      String   @db.VarChar(40)
  isSystem    Boolean  @default(true) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roles           RolePermission[]
  userPermissions UserPermission[]

  @@index([resource, action])
  @@map("permissions")
}

/// Many-to-many: default permissions granted by a role.
model RolePermission {
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// Per-user permission overrides (GRANT adds, DENY revokes regardless of role).
model UserPermission {
  id           String           @id @default(uuid())
  userId       String           @map("user_id")
  permissionId String           @map("permission_id")
  effect       PermissionEffect
  reason       String?
  grantedById  String?          @map("granted_by_id")
  expiresAt    DateTime?        @map("expires_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  user       User       @relation("UserPermissionOverrides", fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedBy  User?      @relation("GrantedPermissionOverrides", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, permissionId])
  @@index([userId, effect])
  @@map("user_permissions")
}

/// Pending level-2 panel operator invitations sent by SUPER_ADMIN.
model AdminInvitation {
  id          String    @id @default(uuid())
  email       String
  displayName String    @map("display_name")
  roleId      String    @map("role_id")
  tokenHash   String    @unique @map("token_hash")
  invitedById String    @map("invited_by_id")
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  role      Role @relation(fields: [roleId], references: [id], onDelete: Restrict)
  invitedBy User @relation("AdminInvitationsSent", fields: [invitedById], references: [id], onDelete: Restrict)

  @@index([email])
  @@index([expiresAt])
  @@map("admin_invitations")
}

