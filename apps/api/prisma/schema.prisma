// Community Marketplace — Prisma schema (canonical)
// Location: apps/api/prisma/schema.prisma
//
// Commands:
//   pnpm --filter @community-marketplace/api exec prisma generate
//   pnpm --filter @community-marketplace/api exec prisma migrate dev

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ══════════════════════════════════════════════════════════════════════════════
// RBAC
// ══════════════════════════════════════════════════════════════════════════════

enum RbacRoleCode {
  SUPER_ADMIN
  ADMIN
  SELLER
  BUYER
}

enum PermissionEffect {
  GRANT
  DENY
}

/// System and custom roles. `code` aligns with @community-marketplace/types RbacRole.
model Role {
  id          String       @id @default(uuid())
  code        RbacRoleCode @unique
  name        String
  description String?
  isSystem    Boolean      @default(true) @map("is_system")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

/// Granular permission definitions. `code` aligns with PermissionCode in packages/types.
model Permission {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(80)
  name        String
  description String?
  resource    String   @db.VarChar(40)
  action      String   @db.VarChar(40)
  isSystem    Boolean  @default(true) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roles           RolePermission[]
  userPermissions UserPermission[]

  @@index([resource, action])
  @@map("permissions")
}

/// Many-to-many: default permissions granted by a role.
model RolePermission {
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// Per-user permission overrides (GRANT adds, DENY revokes regardless of role).
model UserPermission {
  id           String           @id @default(uuid())
  userId       String           @map("user_id")
  permissionId String           @map("permission_id")
  effect       PermissionEffect
  reason       String?
  grantedById  String?          @map("granted_by_id")
  expiresAt    DateTime?        @map("expires_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  user       User       @relation("UserPermissionOverrides", fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedBy  User?      @relation("GrantedPermissionOverrides", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, permissionId])
  @@index([userId, effect])
  @@map("user_permissions")
}

// ══════════════════════════════════════════════════════════════════════════════
// Core domain
// ══════════════════════════════════════════════════════════════════════════════

enum UserStatus {
  active
  inactive
  suspended
}

enum ListingStatus {
  draft
  active
  sold
  archived
  banned
}

enum ListingCondition {
  new
  like_new
  good
  fair
  poor
}

enum PaymentStatus {
  pending
  processing
  succeeded
  failed
  refunded
  disputed
}

enum PayoutStatus {
  pending
  in_transit
  paid
  failed
  canceled
}

enum LedgerEntryType {
  credit
  debit
}

enum RefundStatus {
  pending
  approved
  rejected
  processed
}

enum DisputeStatus {
  open
  under_review
  won
  lost
  closed
}

enum PaymentMethod {
  card
  bank_transfer
  wallet
}

enum ChatMessageType {
  text
  image
  system
}

enum ChatMessageStatus {
  sent
  delivered
  read
}

enum NotificationChannel {
  email
  push
  in_app
}

enum NotificationDeliveryStatus {
  pending
  sent
  failed
}

enum NotificationProviderType {
  email
  push
}

enum NotificationType {
  listing_sold
  listing_created
  new_message
  message_read
  thread_created
  payment_received
  payment_sent
  payment_refunded
  listing_approved
  verification_approved
  verification_rejected
  admin_warning
  system
}

enum ReportStatus {
  open
  reviewing
  resolved
  dismissed
}

enum BanType {
  temporary
  permanent
}

enum ModerationReportStatus {
  pending
  reviewed
  action_taken
}

enum ModerationReportReason {
  fraud
  harassment
  spam
  inappropriate_content
  scams
  fake_listing
}

enum ModerationActionType {
  warn
  suspend
  ban
  delete_listing
  delete_message
}

enum SuspensionDuration {
  hours_24
  days_7
  days_30
  permanent
}

enum AppealStatus {
  pending
  approved
  rejected
}

enum OtpChannel {
  email
  phone
}

enum OtpPurpose {
  login
  register
  password_reset
}

enum UserGender {
  male
  female
  other
  prefer_not_to_say
}

enum VerificationStatus {
  pending
  approved
  rejected
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String?    @map("password_hash")
  displayName     String?    @map("display_name")
  avatarUrl       String?    @map("avatar_url")
  primaryRoleId   String     @map("primary_role_id")
  status          UserStatus @default(active)
  emailVerifiedAt DateTime?  @map("email_verified_at")
  phoneVerifiedAt DateTime?  @map("phone_verified_at")
  profileCompleted Boolean   @default(false) @map("profile_completed")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  primaryRole                Role               @relation(fields: [primaryRoleId], references: [id])
  profile                    UserProfile?
  settings                   UserSettings?
  permissionOverrides        UserPermission[]   @relation("UserPermissionOverrides")
  grantedPermissionOverrides UserPermission[]   @relation("GrantedPermissionOverrides")
  listings                   Listing[]
  buyerPayments              Payment[]          @relation("BuyerPayments")
  sellerPayments             Payment[]          @relation("SellerPayments")
  notifications              Notification[]
  deviceTokens               DeviceToken[]
  authSessions               AuthSession[]
  verifications              UserVerification[]
  bans                       UserBan[]
  auditLogsAsActor           UserAuditLog[]     @relation("UserAuditActor")
  auditLogsAsTarget          UserAuditLog[]     @relation("UserAuditTarget")
  reviewedVerifications      UserVerification[] @relation("VerificationReviewer")
  issuedBans                 UserBan[]          @relation("BanIssuer")
  listingFavorites           ListingFavorite[]
  listingReports             ListingReport[]    @relation("ListingReportReporter")
  resolvedListingReports     ListingReport[]    @relation("ListingReportResolver")
  bannedListings             Listing[]          @relation("ListingBannedBy")
  listingAuditLogs           ListingAuditLog[]  @relation("ListingAuditActor")
  buyerChatThreads           ChatThread[]       @relation("ChatBuyer")
  sellerChatThreads          ChatThread[]       @relation("ChatSeller")
  chatMessages               ChatMessage[]      @relation("ChatMessageSender")
  chatBans                   ChatBan[]          @relation("ChatBannedUser")
  issuedChatBans             ChatBan[]          @relation("ChatBanIssuer")
  flaggedChatMessages        ChatMessageFlag[]  @relation("ChatFlagReporter")
  resolvedChatFlags          ChatMessageFlag[]  @relation("ChatFlagResolver")
  stripeConnectAccount       StripeConnectAccount?
  ledgerEntries              LedgerEntry[]
  payouts                    Payout[]
  requestedRefunds           PaymentRefund[]    @relation("RefundRequester")
  approvedRefunds            PaymentRefund[]    @relation("RefundApprover")
  paymentAuditLogs           PaymentAuditLog[]  @relation("PaymentAuditActor")
  moderationReportsFiled     ModerationReport[] @relation("ModerationReportReporter")
  moderationReportsTargeted  ModerationReport[] @relation("ModerationReportTarget")
  moderationReportsAssigned  ModerationReport[] @relation("ModerationReportAdmin")
  moderationActionsTaken     ModerationAction[] @relation("ModerationActionAdmin")
  moderationActionsReceived  ModerationAction[] @relation("ModerationActionUser")
  moderationAppeals          ModerationAppeal[] @relation("ModerationAppealUser")
  moderationAppealsReviewed  ModerationAppeal[] @relation("ModerationAppealAdmin")
  moderationAuditLogs        ModerationAuditLog[] @relation("ModerationAuditActor")

  @@index([primaryRoleId])
  @@index([status])
  @@map("users")
}

model UserProfile {
  id          String      @id @default(uuid())
  userId      String      @unique @map("user_id")
  bio         String?
  address     String?
  location    String?
  latitude    Decimal?    @db.Decimal(10, 7)
  longitude   Decimal?    @db.Decimal(10, 7)
  phone       String?     @unique
  dateOfBirth DateTime?   @map("date_of_birth") @db.Date
  gender      UserGender?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

/// Seller identity verification submissions.
model UserVerification {
  id                 String             @id @default(uuid())
  userId             String             @map("user_id")
  status             VerificationStatus @default(pending)
  idDocumentFrontUrl String?            @map("id_document_front_url")
  idDocumentBackUrl  String?            @map("id_document_back_url")
  selfieUrl          String?            @map("selfie_url")
  addressProofUrl    String?            @map("address_proof_url")
  reviewedById       String?            @map("reviewed_by_id")
  reviewedAt         DateTime?          @map("reviewed_at")
  rejectionReason    String?            @map("rejection_reason")
  badgeGranted       Boolean            @default(false) @map("badge_granted")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("VerificationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status, createdAt(sort: Desc)])
  @@map("user_verifications")
}

/// User-specific settings and preferences.
model UserSettings {
  id                       String    @id @default(uuid())
  userId                   String    @unique @map("user_id")
  notificationPreferences  Json      @default("{}") @map("notification_preferences")
  privacySettings          Json      @default("{}") @map("privacy_settings")
  communicationPreferences Json      @default("{}") @map("communication_preferences")
  deletionRequestedAt      DateTime? @map("deletion_requested_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

/// User ban records (temporary or permanent).
model UserBan {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  type       BanType
  reason     String?
  bannedById String?   @map("banned_by_id")
  expiresAt  DateTime? @map("expires_at")
  liftedAt   DateTime? @map("lifted_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  bannedBy User? @relation("BanIssuer", fields: [bannedById], references: [id], onDelete: SetNull)

  @@index([userId, liftedAt])
  @@map("user_bans")
}

/// Audit trail for user lifecycle events.
model UserAuditLog {
  id           String   @id @default(uuid())
  eventType    String   @map("event_type") @db.VarChar(60)
  actorId      String?  @map("actor_id")
  targetUserId String?  @map("target_user_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  actor  User? @relation("UserAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  target User? @relation("UserAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([targetUserId, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
  @@map("user_audit_logs")
}

/// One-time passcodes for email or phone verification.
model AuthOtp {
  id          String     @id @default(uuid())
  channel     OtpChannel
  recipient   String     @db.VarChar(255)
  codeHash    String     @map("code_hash")
  purpose     OtpPurpose
  attempts    Int        @default(0)
  maxAttempts Int        @default(5) @map("max_attempts")
  expiresAt   DateTime   @map("expires_at")
  consumedAt  DateTime?  @map("consumed_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([recipient, purpose, consumedAt])
  @@map("auth_otps")
}

/// Refresh-token sessions for login management and rotation.
model AuthSession {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  refreshTokenHash  String    @map("refresh_token_hash")
  userAgent         String?   @map("user_agent")
  ipAddress         String?   @map("ip_address")
  deviceFingerprint String?   @map("device_fingerprint")
  expiresAt         DateTime  @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  lastUsedAt        DateTime? @map("last_used_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("auth_sessions")
}

/// Audit trail for authentication attempts (login, OTP, activation).
model AuthLoginAudit {
  id                String   @id @default(uuid())
  eventType         String   @map("event_type") @db.VarChar(40)
  email             String?  @db.VarChar(255)
  phone             String?  @db.VarChar(20)
  userId            String?  @map("user_id")
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  deviceFingerprint String?  @map("device_fingerprint")
  success           Boolean
  failureReason     String?  @map("failure_reason")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([email, createdAt(sort: Desc)])
  @@index([ipAddress, createdAt(sort: Desc)])
  @@index([phone, createdAt(sort: Desc)])
  @@map("auth_login_audit")
}

/// Staged registration data between OTP verification and email activation.
model PendingRegistration {
  id        String   @id @default(uuid())
  email     String   @unique @db.VarChar(255)
  phone     String   @unique @db.VarChar(20)
  name      String   @db.VarChar(100)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("pending_registrations")
}

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  icon        String?
  description String?
  parentId    String?    @map("parent_id")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryHierarchy")
  listings Listing[]

  @@map("categories")
}

model Listing {
  id              String           @id @default(uuid())
  sellerId        String           @map("seller_id")
  categoryId      String           @map("category_id")
  title           String
  description     String
  price           Decimal          @db.Decimal(12, 2)
  currency        String           @default("USD") @db.Char(3)
  condition       ListingCondition
  status          ListingStatus    @default(draft)
  locationLabel   String           @map("location_label")
  latitude        Decimal          @db.Decimal(10, 7)
  longitude       Decimal          @db.Decimal(10, 7)
  viewCount       Int              @default(0) @map("view_count")
  favoriteCount   Int              @default(0) @map("favorite_count")
  bannedAt        DateTime?        @map("banned_at")
  bannedById      String?          @map("banned_by_id")
  moderationNotes    String?          @map("moderation_notes")
  moderationHiddenAt DateTime?        @map("moderation_hidden_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  seller    User              @relation(fields: [sellerId], references: [id])
  category  Category          @relation(fields: [categoryId], references: [id])
  bannedBy  User?             @relation("ListingBannedBy", fields: [bannedById], references: [id], onDelete: SetNull)
  images    ListingImage[]
  payments  Payment[]
  favorites ListingFavorite[]
  reports   ListingReport[]
  auditLogs ListingAuditLog[]
  chatThreads ChatThread[]
  moderationReports ModerationReport[]

  @@index([status, createdAt(sort: Desc)])
  @@index([sellerId])
  @@index([categoryId])
  @@index([latitude, longitude])
  @@map("listings")
}

model ListingImage {
  id        String  @id @default(uuid())
  listingId String  @map("listing_id")
  url       String
  sortOrder Int     @default(0) @map("sort_order")
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, sortOrder])
  @@map("listing_images")
}

model ListingFavorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  listingId String   @map("listing_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("listing_favorites")
}

model ListingReport {
  id              String       @id @default(uuid())
  listingId       String       @map("listing_id")
  reporterId      String       @map("reporter_id")
  reason          String
  description     String?
  status          ReportStatus @default(open)
  moderationNotes String?      @map("moderation_notes")
  actionTaken     String?      @map("action_taken")
  resolvedById    String?      @map("resolved_by_id")
  resolvedAt      DateTime?    @map("resolved_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  listing    Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reporter   User    @relation("ListingReportReporter", fields: [reporterId], references: [id])
  resolvedBy User?   @relation("ListingReportResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([listingId])
  @@map("listing_reports")
}

model ListingAuditLog {
  id         String         @id @default(uuid())
  listingId  String         @map("listing_id")
  actorId    String?        @map("actor_id")
  eventType  String         @map("event_type")
  fromStatus ListingStatus? @map("from_status")
  toStatus   ListingStatus? @map("to_status")
  metadata   Json?
  createdAt  DateTime       @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  actor   User?   @relation("ListingAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([listingId, createdAt(sort: Desc)])
  @@map("listing_audit_logs")
}

model Payment {
  id                 String        @id @default(uuid())
  orderId            String?       @map("order_id")
  listingId          String        @map("listing_id")
  buyerId            String        @map("buyer_id")
  sellerId           String        @map("seller_id")
  amount             Decimal       @db.Decimal(12, 2)
  platformFee        Decimal?      @map("platform_fee") @db.Decimal(12, 2)
  currency           String        @db.Char(3)
  method             PaymentMethod @default(card)
  status             PaymentStatus @default(pending)
  providerPaymentId  String?       @map("provider_payment_id")
  providerRefundId   String?       @map("provider_refund_id")
  clientSecret       String?       @map("client_secret")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  buyer    User             @relation("BuyerPayments", fields: [buyerId], references: [id])
  seller   User             @relation("SellerPayments", fields: [sellerId], references: [id])
  listing  Listing          @relation(fields: [listingId], references: [id])
  refunds  PaymentRefund[]
  disputes PaymentDispute[]
  ledger   LedgerEntry[]    @relation("PaymentLedger")

  @@index([buyerId, createdAt(sort: Desc)])
  @@index([sellerId, createdAt(sort: Desc)])
  @@index([status])
  @@index([providerPaymentId])
  @@map("payments")
}

model StripeConnectAccount {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id")
  stripeAccountId     String   @unique @map("stripe_account_id")
  chargesEnabled      Boolean  @default(false) @map("charges_enabled")
  payoutsEnabled      Boolean  @default(false) @map("payouts_enabled")
  onboardingComplete  Boolean  @default(false) @map("onboarding_complete")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("stripe_connect_accounts")
}

model Payout {
  id                String       @id @default(uuid())
  sellerId          String       @map("seller_id")
  amount            Decimal      @db.Decimal(12, 2)
  currency          String       @db.Char(3)
  status            PayoutStatus @default(pending)
  providerPayoutId  String?      @map("provider_payout_id")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  seller User @relation(fields: [sellerId], references: [id])

  @@index([sellerId, createdAt(sort: Desc)])
  @@map("payouts")
}

model LedgerEntry {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  type        LedgerEntryType
  amount      Decimal         @db.Decimal(12, 2)
  currency    String          @db.Char(3)
  referenceId String?         @map("reference_id")
  paymentId   String?         @map("payment_id")
  metadata    Json?
  createdAt   DateTime        @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id])
  payment Payment? @relation("PaymentLedger", fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([paymentId])
  @@map("ledger_entries")
}

model PaymentRefund {
  id               String       @id @default(uuid())
  paymentId        String       @map("payment_id")
  requestedById    String       @map("requested_by_id")
  approvedById     String?      @map("approved_by_id")
  amount           Decimal      @db.Decimal(12, 2)
  reason           String?
  status           RefundStatus @default(pending)
  providerRefundId String?      @map("provider_refund_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  payment     Payment @relation(fields: [paymentId], references: [id])
  requestedBy User    @relation("RefundRequester", fields: [requestedById], references: [id])
  approvedBy  User?   @relation("RefundApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([paymentId])
  @@index([status])
  @@map("payment_refunds")
}

model PaymentDispute {
  id               String        @id @default(uuid())
  paymentId        String        @map("payment_id")
  providerDisputeId String       @unique @map("provider_dispute_id")
  status           DisputeStatus @default(open)
  reason           String?
  evidence         Json?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@map("payment_disputes")
}

model PaymentAuditLog {
  id        String   @id @default(uuid())
  paymentId String?  @map("payment_id")
  actorId   String?  @map("actor_id")
  eventType String   @map("event_type")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  actor User? @relation("PaymentAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([paymentId, createdAt(sort: Desc)])
  @@map("payment_audit_logs")
}

model ProcessedStripeEvent {
  id            String   @id @default(uuid())
  stripeEventId String   @unique @map("stripe_event_id")
  eventType     String   @map("event_type")
  processedAt   DateTime @default(now()) @map("processed_at")

  @@map("processed_stripe_events")
}

model Notification {
  id        String                     @id @default(uuid())
  userId    String                     @map("user_id")
  type      NotificationType
  title     String
  message   String                     @map("body")
  data      Json?
  channel   NotificationChannel        @default(in_app)
  status    NotificationDeliveryStatus @default(sent)
  actionUrl String?                    @map("action_url")
  readAt    DateTime?                  @map("read_at")
  createdAt DateTime                   @default(now()) @map("created_at")

  user User              @relation(fields: [userId], references: [id])
  logs NotificationLog[]

  @@index([userId, readAt, createdAt(sort: Desc)])
  @@index([userId, channel, createdAt(sort: Desc)])
  @@map("notifications")
}

model NotificationTemplate {
  id            String              @id @default(uuid())
  key           String
  titleTemplate String              @map("title_template")
  bodyTemplate  String              @map("body_template")
  channel       NotificationChannel
  variables     Json?
  version       Int                 @default(1)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@unique([key, channel, version])
  @@index([key, channel])
  @@map("notification_templates")
}

model NotificationProvider {
  id           String                   @id @default(uuid())
  name         String                   @unique
  type         NotificationProviderType
  config       Json
  enabled      Boolean                  @default(true)
  failureCount Int                      @default(0) @map("failure_count")
  disabledAt   DateTime?                @map("disabled_at")
  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @updatedAt @map("updated_at")

  logs NotificationLog[]

  @@map("notification_providers")
}

model NotificationLog {
  id             String                     @id @default(uuid())
  notificationId String?                    @map("notification_id")
  providerId     String                     @map("provider_id")
  status         NotificationDeliveryStatus
  response       Json?
  attempts       Int                        @default(1)
  createdAt      DateTime                   @default(now()) @map("created_at")

  notification Notification?        @relation(fields: [notificationId], references: [id], onDelete: SetNull)
  provider     NotificationProvider @relation(fields: [providerId], references: [id])

  @@index([notificationId, createdAt(sort: Desc)])
  @@index([providerId, createdAt(sort: Desc)])
  @@map("notification_logs")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String
  platform  String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, token])
  @@index([userId, isActive])
  @@map("device_tokens")
}

model SearchAnalyticsEvent {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  query       String
  entity      String
  resultCount Int      @default(0) @map("result_count")
  clickedId   String?  @map("clicked_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([query, createdAt(sort: Desc)])
  @@index([entity, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("search_analytics_events")
}

// ══════════════════════════════════════════════════════════════════════════════
// Chat
// ══════════════════════════════════════════════════════════════════════════════

model ChatThread {
  id               String    @id @default(uuid())
  buyerId          String    @map("buyer_id")
  sellerId         String    @map("seller_id")
  listingId        String    @map("listing_id")
  lastMessageAt    DateTime? @map("last_message_at")
  archivedByBuyer  Boolean   @default(false) @map("archived_by_buyer")
  archivedBySeller Boolean   @default(false) @map("archived_by_seller")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  buyer    User          @relation("ChatBuyer", fields: [buyerId], references: [id])
  seller   User          @relation("ChatSeller", fields: [sellerId], references: [id])
  listing  Listing       @relation(fields: [listingId], references: [id])
  messages ChatMessage[]

  @@unique([buyerId, sellerId, listingId])
  @@index([buyerId, lastMessageAt(sort: Desc)])
  @@index([sellerId, lastMessageAt(sort: Desc)])
  @@index([listingId])
  @@map("chat_threads")
}

model ChatMessage {
  id            String          @id @default(uuid())
  threadId      String          @map("thread_id")
  senderId      String          @map("sender_id")
  content       String
  messageType   ChatMessageType @default(text) @map("message_type")
  attachmentUrl String?         @map("attachment_url")
  readBy        String[]        @default([]) @map("read_by")
  editedAt      DateTime?       @map("edited_at")
  deletedAt     DateTime?       @map("deleted_at")
  createdAt     DateTime        @default(now()) @map("created_at")

  thread ChatThread        @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User              @relation("ChatMessageSender", fields: [senderId], references: [id])
  flags  ChatMessageFlag[]
  moderationReports ModerationReport[]

  @@index([threadId, createdAt(sort: Desc)])
  @@map("chat_messages")
}

model ChatMessageFlag {
  id              String       @id @default(uuid())
  messageId       String       @map("message_id")
  reporterId      String?      @map("reporter_id")
  reason          String
  status          ReportStatus @default(open)
  moderationNotes String?      @map("moderation_notes")
  resolvedById    String?      @map("resolved_by_id")
  resolvedAt      DateTime?    @map("resolved_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  message    ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reporter   User?       @relation("ChatFlagReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  resolvedBy User?       @relation("ChatFlagResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([messageId])
  @@map("chat_message_flags")
}

model ChatBan {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  bannedById      String?   @map("banned_by_id")
  reason          String?
  moderationNotes String?   @map("moderation_notes")
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  user     User  @relation("ChatBannedUser", fields: [userId], references: [id], onDelete: Cascade)
  bannedBy User? @relation("ChatBanIssuer", fields: [bannedById], references: [id], onDelete: SetNull)

  @@index([userId, expiresAt])
  @@map("chat_bans")
}

// ══════════════════════════════════════════════════════════════════════════════
// Moderation
// ══════════════════════════════════════════════════════════════════════════════

model ModerationReport {
  id           String                 @id @default(uuid())
  reporterId   String                 @map("reporter_id")
  targetUserId String?                @map("target_user_id")
  listingId    String?                @map("listing_id")
  messageId    String?                @map("message_id")
  reason       ModerationReportReason
  description  String?
  status       ModerationReportStatus @default(pending)
  adminId      String?                @map("admin_id")
  autoFlagged  Boolean                @default(false) @map("auto_flagged")
  autoHidden   Boolean                @default(false) @map("auto_hidden")
  notes        String?
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")

  reporter   User              @relation("ModerationReportReporter", fields: [reporterId], references: [id])
  targetUser User?             @relation("ModerationReportTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  listing    Listing?          @relation(fields: [listingId], references: [id], onDelete: SetNull)
  message    ChatMessage?      @relation(fields: [messageId], references: [id], onDelete: SetNull)
  admin      User?             @relation("ModerationReportAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  appeals    ModerationAppeal[]
  actions    ModerationAction[]

  @@index([status, createdAt(sort: Desc)])
  @@index([listingId])
  @@index([targetUserId])
  @@index([messageId])
  @@index([reporterId])
  @@map("moderation_reports")
}

model ModerationAction {
  id                 String               @id @default(uuid())
  adminId            String               @map("admin_id")
  userId             String?              @map("user_id")
  listingId          String?              @map("listing_id")
  messageId          String?              @map("message_id")
  reportId           String?              @map("report_id")
  actionType         ModerationActionType @map("action_type")
  suspensionDuration SuspensionDuration?  @map("suspension_duration")
  notes              String?
  expiresAt          DateTime?            @map("expires_at")
  liftedAt           DateTime?            @map("lifted_at")
  createdAt          DateTime             @default(now()) @map("created_at")

  admin   User              @relation("ModerationActionAdmin", fields: [adminId], references: [id])
  user    User?             @relation("ModerationActionUser", fields: [userId], references: [id], onDelete: SetNull)
  report  ModerationReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  appeals ModerationAppeal[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([reportId])
  @@index([expiresAt, liftedAt])
  @@map("moderation_actions")
}

model ModerationAppeal {
  id                 String       @id @default(uuid())
  userId             String       @map("user_id")
  reportId           String?      @map("report_id")
  moderationActionId String?      @map("moderation_action_id")
  message            String
  status             AppealStatus @default(pending)
  adminId            String?      @map("admin_id")
  adminNotes         String?      @map("admin_notes")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  user             User              @relation("ModerationAppealUser", fields: [userId], references: [id])
  report           ModerationReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  moderationAction ModerationAction? @relation(fields: [moderationActionId], references: [id], onDelete: SetNull)
  admin            User?             @relation("ModerationAppealAdmin", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([userId])
  @@map("moderation_appeals")
}

model ModerationAuditLog {
  id        String   @id @default(uuid())
  eventType String   @map("event_type") @db.VarChar(60)
  actorId   String?  @map("actor_id")
  reportId  String?  @map("report_id")
  userId    String?  @map("user_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  actor User? @relation("ModerationAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([reportId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
  @@map("moderation_audit_logs")
}
