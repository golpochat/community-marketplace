model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String?    @map("password_hash")
  displayName     String?    @map("display_name")
  avatarUrl       String?    @map("avatar_url")
  primaryRoleId   String     @map("primary_role_id")
  status          UserStatus @default(active)
  emailVerifiedAt DateTime?  @map("email_verified_at")
  phoneVerifiedAt DateTime?  @map("phone_verified_at")
  profileCompleted Boolean   @default(false) @map("profile_completed")
  sellerStatus               SellerStatus @default(unverified) @map("seller_status")
  unverifiedListingCount     Int          @default(0) @map("unverified_listing_count")
  phoneVerified              Boolean      @default(false) @map("phone_verified")
  emailVerified              Boolean      @default(false) @map("email_verified")
  idVerified                 Boolean      @default(false) @map("id_verified")
  verificationRequestedAt    DateTime?    @map("verification_requested_at")
  verificationCompletedAt    DateTime?    @map("verification_completed_at")
  verificationRejectedReason String?      @map("verification_rejected_reason") @db.Text
  sellerLimit                Int          @default(5) @map("seller_limit")
  approvedListingCount       Int          @default(0) @map("approved_listing_count")
  storeSlotLimit             Int          @default(1) @map("store_slot_limit")
  customPlatformFeePercent   Decimal?     @map("custom_platform_fee_percent") @db.Decimal(5, 2)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  primaryRole                Role               @relation(fields: [primaryRoleId], references: [id])
  profile                    UserProfile?
  settings                   UserSettings?
  permissionOverrides        UserPermission[]   @relation("UserPermissionOverrides")
  grantedPermissionOverrides UserPermission[]   @relation("GrantedPermissionOverrides")
  listings                   Listing[]
  buyerPayments              Payment[]          @relation("BuyerPayments")
  sellerPayments             Payment[]          @relation("SellerPayments")
  notifications              Notification[]
  deviceTokens               DeviceToken[]
  authSessions               AuthSession[]
  verifications              UserVerification[]
  bans                       UserBan[]
  auditLogsAsActor           UserAuditLog[]     @relation("UserAuditActor")
  auditLogsAsTarget          UserAuditLog[]     @relation("UserAuditTarget")
  reviewedVerifications      UserVerification[] @relation("VerificationReviewer")
  reviewedSellerVerifications SellerVerificationRequest[] @relation("SellerVerificationReviewer")
  issuedBans                 UserBan[]          @relation("BanIssuer")
  listingFavorites           ListingFavorite[]
  listingReports             ListingReport[]    @relation("ListingReportReporter")
  resolvedListingReports     ListingReport[]    @relation("ListingReportResolver")
  bannedListings             Listing[]          @relation("ListingBannedBy")
  listingAuditLogs           ListingAuditLog[]  @relation("ListingAuditActor")
  buyerChatThreads           ChatThread[]       @relation("ChatBuyer")
  sellerChatThreads          ChatThread[]       @relation("ChatSeller")
  blockedChatThreads         ChatThread[]       @relation("ChatThreadBlocker")
  chatMessages               ChatMessage[]      @relation("ChatMessageSender")
  chatBans                   ChatBan[]          @relation("ChatBannedUser")
  issuedChatBans             ChatBan[]          @relation("ChatBanIssuer")
  flaggedChatMessages        ChatMessageFlag[]  @relation("ChatFlagReporter")
  resolvedChatFlags          ChatMessageFlag[]  @relation("ChatFlagResolver")
  stripeConnectAccount       StripeConnectAccount?
  ledgerEntries              LedgerEntry[]
  payouts                    Payout[]
  requestedRefunds           PaymentRefund[]    @relation("RefundRequester")
  approvedRefunds            PaymentRefund[]    @relation("RefundApprover")
  paymentAuditLogs           PaymentAuditLog[]  @relation("PaymentAuditActor")
  moderationReportsFiled     ModerationReport[] @relation("ModerationReportReporter")
  moderationReportsTargeted  ModerationReport[] @relation("ModerationReportTarget")
  moderationReportsAssigned  ModerationReport[] @relation("ModerationReportAdmin")
  moderationActionsTaken     ModerationAction[] @relation("ModerationActionAdmin")
  moderationActionsReceived  ModerationAction[] @relation("ModerationActionUser")
  moderationAppeals          ModerationAppeal[] @relation("ModerationAppealUser")
  moderationAppealsReviewed  ModerationAppeal[] @relation("ModerationAppealAdmin")
  moderationAuditLogs        ModerationAuditLog[] @relation("ModerationAuditActor")
  listingReviewMessages      ListingReviewMessage[] @relation("ListingReviewSender")
  buyerDisputes              MarketplaceDispute[] @relation("DisputeBuyer")
  sellerDisputes             MarketplaceDispute[] @relation("DisputeSeller")
  resolvedDisputes           MarketplaceDispute[] @relation("DisputeResolver")
  disputeEvidenceUploads     DisputeEvidence[]    @relation("DisputeEvidenceUploader")
  disputeMessages            DisputeMessage[]     @relation("DisputeMessageSender")
  deliveryChangeLogsAsSeller DeliveryChangeLog[]    @relation("DeliveryChangeSeller")
  deliveryChangeLogsReviewed DeliveryChangeLog[]    @relation("DeliveryChangeReviewer")
  priceChangeLogsAsSeller    PriceChangeLog[]       @relation("PriceChangeSeller")
  priceChangeLogsReviewed    PriceChangeLog[]       @relation("PriceChangeReviewer")
  listingSharesAsSeller      ListingShare[]         @relation("ListingShareSeller")
  sellerReviewsReceived      SellerReview[]         @relation("SellerReviewsReceived")
  sellerReviewsGiven         SellerReview[]         @relation("SellerReviewsGiven")
  buyerReviewsReceived       BuyerReview[]          @relation("BuyerReviewsReceived")
  buyerReviewsGiven          BuyerReview[]          @relation("BuyerReviewsGiven")
  sellerVerificationRequests SellerVerificationRequest[]
  sellerStatusHistory        SellerStatusHistory[]  @relation("SellerStatusHistoryUser")
  sellerStatusChanges        SellerStatusHistory[]  @relation("SellerStatusHistoryActor")
  fraudSignals               FraudSignal[]
  buyerWallet                BuyerWallet?
  walletTransactions         WalletTransaction[]
  cashbackGrants             CashbackGrant[]
  platformPurchases          PlatformPurchase[]
  stores                     Store[]
  adminInvitationsSent       AdminInvitation[] @relation("AdminInvitationsSent")

  @@index([primaryRoleId])
  @@index([status])
  @@index([sellerStatus])
  @@map("users")
}

/// Public storefront owned by a seller account (1+ per user when store slots allow).
model Store {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  slug        String   @unique
  description String?  @db.Text
  logoUrl     String?  @map("logo_url")
  bannerUrl   String?  @map("banner_url")
  location        String?
  contactSettings Json?    @map("contact_settings")
  openingHours    Json?    @map("opening_hours")
  policies        Json?    @map("policies")
  isPrimary       Boolean  @default(true) @map("is_primary")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings Listing[]

  @@index([userId])
  @@map("stores")
}

/// Seller identity verification submissions (manual admin review).
model SellerVerificationRequest {
  id                  String             @id @default(uuid())
  userId              String             @map("user_id")
  phoneNumber         String?            @map("phone_number")
  idDocumentPath      String?            @map("id_document_path")
  selfiePath          String?            @map("selfie_path")
  addressDocumentPath String?            @map("address_document_path")
  status              VerificationStatus @default(pending)
  priority            Boolean            @default(false)
  reviewedById        String?            @map("reviewed_by")
  reviewedAt          DateTime?          @map("reviewed_at")
  rejectionReason     String?            @map("rejection_reason") @db.Text
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("SellerVerificationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status, createdAt(sort: Desc)])
  @@map("seller_verification_requests")
}

/// Audit trail for seller_status transitions.
model SellerStatusHistory {
  id        String       @id @default(uuid())
  userId    String       @map("user_id")
  oldStatus SellerStatus @map("old_status")
  newStatus SellerStatus @map("new_status")
  changedBy String?      @map("changed_by")
  reason    String?      @db.Text
  createdAt DateTime     @default(now()) @map("created_at")

  user   User  @relation("SellerStatusHistoryUser", fields: [userId], references: [id], onDelete: Cascade)
  actor  User? @relation("SellerStatusHistoryActor", fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@map("seller_status_history")
}

model UserProfile {
  id          String      @id @default(uuid())
  userId      String      @unique @map("user_id")
  bio         String?
  address     String?
  location    String?
  latitude    Decimal?    @db.Decimal(10, 7)
  longitude   Decimal?    @db.Decimal(10, 7)
  phone       String?     @unique
  dateOfBirth DateTime?   @map("date_of_birth") @db.Date
  gender      UserGender?
  communityArea         String?   @map("community_area")
  referralCode          String?   @unique @map("referral_code")
  referralCount         Int       @default(0) @map("referral_count")
  referredById          String?   @map("referred_by_id")
  isCommunityAmbassador Boolean   @default(false) @map("is_community_ambassador")
  isBusinessAccount     Boolean   @default(false) @map("is_business_account")
  businessName          String?   @map("business_name")
  businessWebsite         String?   @map("business_website")
  businessLogoUrl         String?   @map("business_logo_url")
  storeBannerUrl          String?   @map("store_banner_url")
  onboardingDismissedAt DateTime? @map("onboarding_dismissed_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

/// Seller identity verification submissions.
model UserVerification {
  id                 String             @id @default(uuid())
  userId             String             @map("user_id")
  status             VerificationStatus @default(pending)
  idDocumentFrontUrl String?            @map("id_document_front_url")
  idDocumentBackUrl  String?            @map("id_document_back_url")
  selfieUrl          String?            @map("selfie_url")
  addressProofUrl    String?            @map("address_proof_url")
  reviewedById       String?            @map("reviewed_by_id")
  reviewedAt         DateTime?          @map("reviewed_at")
  rejectionReason    String?            @map("rejection_reason")
  badgeGranted       Boolean            @default(false) @map("badge_granted")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("VerificationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status, createdAt(sort: Desc)])
  @@map("user_verifications")
}

/// User-specific settings and preferences.
model UserSettings {
  id                       String    @id @default(uuid())
  userId                   String    @unique @map("user_id")
  notificationPreferences  Json      @default("{}") @map("notification_preferences")
  privacySettings          Json      @default("{}") @map("privacy_settings")
  communicationPreferences Json      @default("{}") @map("communication_preferences")
  deletionRequestedAt      DateTime? @map("deletion_requested_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

/// User ban records (temporary or permanent).
model UserBan {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  type       BanType
  reason     String?
  bannedById String?   @map("banned_by_id")
  expiresAt  DateTime? @map("expires_at")
  liftedAt   DateTime? @map("lifted_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  bannedBy User? @relation("BanIssuer", fields: [bannedById], references: [id], onDelete: SetNull)

  @@index([userId, liftedAt])
  @@map("user_bans")
}

/// Audit trail for user lifecycle events.
model UserAuditLog {
  id           String   @id @default(uuid())
  eventType    String   @map("event_type") @db.VarChar(60)
  actorId      String?  @map("actor_id")
  targetUserId String?  @map("target_user_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  actor  User? @relation("UserAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  target User? @relation("UserAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([targetUserId, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
  @@map("user_audit_logs")
}

/// One-time passcodes for email or phone verification.
model AuthOtp {
  id          String     @id @default(uuid())
  channel     OtpChannel
  recipient   String     @db.VarChar(255)
  codeHash    String     @map("code_hash")
  purpose     OtpPurpose
  attempts    Int        @default(0)
  maxAttempts Int        @default(5) @map("max_attempts")
  expiresAt   DateTime   @map("expires_at")
  consumedAt  DateTime?  @map("consumed_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([recipient, purpose, consumedAt])
  @@map("auth_otps")
}

/// Refresh-token sessions for login management and rotation.
model AuthSession {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  refreshTokenHash  String    @map("refresh_token_hash")
  userAgent         String?   @map("user_agent")
  ipAddress         String?   @map("ip_address")
  deviceFingerprint String?   @map("device_fingerprint")
  expiresAt         DateTime  @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  lastUsedAt        DateTime? @map("last_used_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("auth_sessions")
}

/// Audit trail for authentication attempts (login, OTP, activation).
model AuthLoginAudit {
  id                String   @id @default(uuid())
  eventType         String   @map("event_type") @db.VarChar(40)
  email             String?  @db.VarChar(255)
  phone             String?  @db.VarChar(20)
  userId            String?  @map("user_id")
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  deviceFingerprint String?  @map("device_fingerprint")
  success           Boolean
  failureReason     String?  @map("failure_reason")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([email, createdAt(sort: Desc)])
  @@index([ipAddress, createdAt(sort: Desc)])
  @@index([phone, createdAt(sort: Desc)])
  @@map("auth_login_audit")
}

/// Staged registration data between OTP verification and email activation.
enum RegistrationAccountType {
  buyer
  seller

  @@map("RegistrationAccountType")
}

model PendingRegistration {
  id           String                   @id @default(uuid())
  email        String                   @unique @db.VarChar(255)
  phone        String                   @unique @db.VarChar(20)
  name         String                   @db.VarChar(100)
  accountType  RegistrationAccountType  @default(buyer) @map("account_type")
  passwordHash String?                  @map("password_hash")
  expiresAt    DateTime                 @map("expires_at")
  createdAt    DateTime                 @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("pending_registrations")
}

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  icon        String?
  description String?
  parentId    String?    @map("parent_id")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryHierarchy")
  listings Listing[]

  @@map("categories")
}

model Listing {
  id              String           @id @default(uuid())
  sellerId        String           @map("seller_id")
  storeId         String           @map("store_id")
  categoryId      String           @map("category_id")
  title           String
  description     String
  price           Decimal          @db.Decimal(12, 2)
  originalPrice   Decimal?         @map("original_price") @db.Decimal(12, 2)
  salePrice       Decimal?         @map("sale_price") @db.Decimal(12, 2)
  discountPercent Int?             @map("discount_percent")
  currency        String           @default("USD") @db.Char(3)
  condition       ListingCondition
  status          ListingStatus    @default(draft)
  isPaid          Boolean          @default(false) @map("is_paid")
  packageType     ListingPackageType @default(FREE) @map("package_type")
  activatedAt     DateTime?        @map("activated_at")
  expiresAt       DateTime?        @map("expires_at")
  endedAt         DateTime?        @map("ended_at")
  rejectionReason String?          @map("rejection_reason")
  removalReason   String?          @map("removal_reason")
  locationLabel   String           @map("location_label")
  latitude        Decimal          @db.Decimal(10, 7)
  longitude       Decimal          @db.Decimal(10, 7)
  viewCount       Int              @default(0) @map("view_count")
  favoriteCount   Int              @default(0) @map("favorite_count")
  bannedAt        DateTime?        @map("banned_at")
  bannedById      String?          @map("banned_by_id")
  moderationNotes    String?          @map("moderation_notes")
  moderationHiddenAt DateTime?        @map("moderation_hidden_at")
  attributes         Json?            @map("attributes")
  isFeatured         Boolean          @default(false) @map("is_featured")
  featuredUntil      DateTime?        @map("featured_until")
  featuredPlacement  String?          @map("featured_placement")
  boostedUntil       DateTime?        @map("boosted_until")
  requiresFraudReview Boolean         @default(false) @map("requires_fraud_review")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  seller    User              @relation(fields: [sellerId], references: [id])
  store     Store             @relation(fields: [storeId], references: [id])
  category  Category          @relation(fields: [categoryId], references: [id])
  bannedBy  User?             @relation("ListingBannedBy", fields: [bannedById], references: [id], onDelete: SetNull)
  images    ListingImage[]
  payments  Payment[]
  favorites ListingFavorite[]
  reports   ListingReport[]
  auditLogs ListingAuditLog[]
  chatThreads ChatThread[]
  moderationReports ModerationReport[]
  reviewMessages ListingReviewMessage[]
  deliveryOptions ListingDeliveryOption[]
  platformPurchases PlatformPurchase[]
  deliveryChangeLogs DeliveryChangeLog[]
  priceChangeLogs    PriceChangeLog[]
  shortLinks         ShortLink[]
  shares             ListingShare[]
  statusChangeLogs   ListingStatusChangeLog[]
  sellerReviews      SellerReview[]
  buyerReviews       BuyerReview[]
  marketplaceDisputes MarketplaceDispute[]
  fraudSignals        FraudSignal[]

  @@index([status, createdAt(sort: Desc)])
  @@index([status, expiresAt])
  @@index([sellerId])
  @@index([storeId])
  @@index([categoryId])
  @@index([latitude, longitude])
  @@map("listings")
}

