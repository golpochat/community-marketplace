// Community Marketplace — Prisma schema (canonical)
// Location: apps/api/prisma/schema.prisma
//
// Commands:
//   pnpm --filter @community-marketplace/api exec prisma generate
//   pnpm --filter @community-marketplace/api exec prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ══════════════════════════════════════════════════════════════════════════════
// RBAC
// ══════════════════════════════════════════════════════════════════════════════

enum RbacRoleCode {
  SUPER_ADMIN
  ADMIN
  SELLER
  BUYER
}

enum PermissionEffect {
  GRANT
  DENY
}

/// System and custom roles. `code` aligns with @community-marketplace/types RbacRole.
model Role {
  id          String       @id @default(uuid())
  code        RbacRoleCode @unique
  name        String
  description String?
  isSystem    Boolean      @default(true) @map("is_system")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

/// Granular permission definitions. `code` aligns with PermissionCode in packages/types.
model Permission {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(80)
  name        String
  description String?
  resource    String   @db.VarChar(40)
  action      String   @db.VarChar(40)
  isSystem    Boolean  @default(true) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roles           RolePermission[]
  userPermissions UserPermission[]

  @@index([resource, action])
  @@map("permissions")
}

/// Many-to-many: default permissions granted by a role.
model RolePermission {
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// Per-user permission overrides (GRANT adds, DENY revokes regardless of role).
model UserPermission {
  id           String           @id @default(uuid())
  userId       String           @map("user_id")
  permissionId String           @map("permission_id")
  effect       PermissionEffect
  reason       String?
  grantedById  String?          @map("granted_by_id")
  expiresAt    DateTime?        @map("expires_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  user       User       @relation("UserPermissionOverrides", fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedBy  User?      @relation("GrantedPermissionOverrides", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, permissionId])
  @@index([userId, effect])
  @@map("user_permissions")
}

// ══════════════════════════════════════════════════════════════════════════════
// Core domain
// ══════════════════════════════════════════════════════════════════════════════

enum UserStatus {
  active
  inactive
  suspended
}

enum ListingStatus {
  draft
  active
  sold
  archived
}

enum ListingCondition {
  new
  like_new
  good
  fair
  poor
}

enum PaymentStatus {
  pending
  processing
  completed
  failed
  refunded
}

enum PaymentMethod {
  card
  bank_transfer
  wallet
}

enum ChatMessageType {
  text
  image
  system
}

enum ChatMessageStatus {
  sent
  delivered
  read
}

enum NotificationType {
  listing_sold
  new_message
  payment_received
  payment_sent
  listing_approved
  system
}

enum ReportStatus {
  open
  reviewing
  resolved
  dismissed
}

enum BanType {
  temporary
  permanent
}

enum OtpChannel {
  email
  phone
}

enum OtpPurpose {
  login
  register
  password_reset
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String?    @map("password_hash")
  displayName     String?    @map("display_name")
  avatarUrl       String?    @map("avatar_url")
  primaryRoleId   String     @map("primary_role_id")
  status          UserStatus @default(active)
  emailVerifiedAt DateTime?  @map("email_verified_at")
  phoneVerifiedAt DateTime?  @map("phone_verified_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  primaryRole                Role             @relation(fields: [primaryRoleId], references: [id])
  profile                    UserProfile?
  permissionOverrides        UserPermission[] @relation("UserPermissionOverrides")
  grantedPermissionOverrides UserPermission[] @relation("GrantedPermissionOverrides")
  listings                   Listing[]
  buyerPayments              Payment[]        @relation("BuyerPayments")
  sellerPayments             Payment[]        @relation("SellerPayments")
  notifications              Notification[]
  deviceTokens               DeviceToken[]
  authSessions               AuthSession[]

  @@index([primaryRoleId])
  @@index([status])
  @@map("users")
}

model UserProfile {
  id       String  @id @default(uuid())
  userId   String  @unique @map("user_id")
  bio      String?
  location String?
  phone    String? @unique
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

/// One-time passcodes for email or phone verification.
model AuthOtp {
  id          String     @id @default(uuid())
  channel     OtpChannel
  recipient   String     @db.VarChar(255)
  codeHash    String     @map("code_hash")
  purpose     OtpPurpose
  attempts    Int        @default(0)
  maxAttempts Int        @default(5) @map("max_attempts")
  expiresAt   DateTime   @map("expires_at")
  consumedAt  DateTime?  @map("consumed_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([recipient, purpose, consumedAt])
  @@map("auth_otps")
}

/// Refresh-token sessions for login management and rotation.
model AuthSession {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  refreshTokenHash  String    @map("refresh_token_hash")
  userAgent         String?   @map("user_agent")
  ipAddress         String?   @map("ip_address")
  deviceFingerprint String?   @map("device_fingerprint")
  expiresAt         DateTime  @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  lastUsedAt        DateTime? @map("last_used_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("auth_sessions")
}

/// Audit trail for authentication attempts (login, OTP, activation).
model AuthLoginAudit {
  id                String   @id @default(uuid())
  eventType         String   @map("event_type") @db.VarChar(40)
  email             String?  @db.VarChar(255)
  phone             String?  @db.VarChar(20)
  userId            String?  @map("user_id")
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  deviceFingerprint String?  @map("device_fingerprint")
  success           Boolean
  failureReason     String?  @map("failure_reason")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([email, createdAt(sort: Desc)])
  @@index([ipAddress, createdAt(sort: Desc)])
  @@index([phone, createdAt(sort: Desc)])
  @@map("auth_login_audit")
}

/// Staged registration data between OTP verification and email activation.
model PendingRegistration {
  id        String   @id @default(uuid())
  email     String   @unique @db.VarChar(255)
  phone     String   @unique @db.VarChar(20)
  name      String   @db.VarChar(100)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("pending_registrations")
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  parentId    String?   @map("parent_id")
  isActive    Boolean   @default(true) @map("is_active")
  listings    Listing[]

  @@map("categories")
}

model Listing {
  id          String           @id @default(uuid())
  sellerId    String           @map("seller_id")
  categoryId  String           @map("category_id")
  title       String
  description String
  price       Decimal          @db.Decimal(12, 2)
  currency    String           @default("USD") @db.Char(3)
  condition   ListingCondition
  status      ListingStatus    @default(draft)
  location    String
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  seller   User           @relation(fields: [sellerId], references: [id])
  category Category       @relation(fields: [categoryId], references: [id])
  images   ListingImage[]
  payments Payment[]

  @@index([status, createdAt(sort: Desc)])
  @@index([sellerId])
  @@map("listings")
}

model ListingImage {
  id        String  @id @default(uuid())
  listingId String  @map("listing_id")
  url       String
  altText   String? @map("alt_text")
  sortOrder Int     @default(0) @map("sort_order")
  isPrimary Boolean @default(false) @map("is_primary")
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_images")
}

model Payment {
  id                    String        @id @default(uuid())
  buyerId               String        @map("buyer_id")
  sellerId              String        @map("seller_id")
  listingId             String        @map("listing_id")
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @db.Char(3)
  method                PaymentMethod
  status                PaymentStatus @default(pending)
  stripePaymentIntentId String?       @map("stripe_payment_intent_id")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  buyer   User    @relation("BuyerPayments", fields: [buyerId], references: [id])
  seller  User    @relation("SellerPayments", fields: [sellerId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])

  @@map("payments")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  actionUrl String?          @map("action_url")
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, read, createdAt(sort: Desc)])
  @@map("notifications")
}

model DeviceToken {
  id       String  @id @default(uuid())
  userId   String  @map("user_id")
  token    String
  platform String
  isActive Boolean @default(true) @map("is_active")
  user     User    @relation(fields: [userId], references: [id])

  @@map("device_tokens")
}
