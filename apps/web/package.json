{
  "name": "@community-marketplace/web",
  "version": "0.0.0",
  "private": true,
  "description": "Community Marketplace public web application",
  "scripts": {
    "predev": "node scripts/clean-pwa-sw.mjs",
    "dev": "node scripts/dev.mjs",
    "prebuild": "node ../../scripts/brand/export-sellnearby.mjs && node scripts/generate-og-home.mjs",
    "build": "next build",
    "start": "next start --port 3000",
    "clean": "rimraf .next out tsconfig.tsbuildinfo && node scripts/clean-pwa-sw.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "next lint",
    "brand:export": "node ../../scripts/brand/export-sellnearby.mjs"
  },
  "dependencies": {
    "@community-marketplace/config": "workspace:*",
    "@community-marketplace/types": "workspace:*",
    "@community-marketplace/ui": "workspace:*",
    "@community-marketplace/ui-dashboard": "workspace:*",
    "@community-marketplace/utils": "workspace:*",
    "@community-marketplace/validation": "workspace:*",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "lucide-react": "^0.469.0",
    "next": "^15.1.3",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.2",
    "socket.io-client": "^4.8.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "eslint-plugin-design-system": "file:./eslint-plugin-design-system",
    "postcss": "^8.4.49",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2"
  }
}
