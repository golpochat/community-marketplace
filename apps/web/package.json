{
  "name": "@community-marketplace/web",
  "version": "0.0.0",
  "private": true,
  "description": "Community Marketplace public web application",
  "scripts": {
    "predev": "node scripts/clean-pwa-sw.mjs",
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "clean": "rimraf .next out tsconfig.tsbuildinfo && node scripts/clean-pwa-sw.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "next lint"
  },
  "dependencies": {
    "@community-marketplace/config": "workspace:*",
    "@community-marketplace/types": "workspace:*",
    "@community-marketplace/ui": "workspace:*",
    "@community-marketplace/ui-dashboard": "workspace:*",
    "@community-marketplace/utils": "workspace:*",
    "@community-marketplace/validation": "workspace:*",
    "@ducanh2912/next-pwa": "^10.2.9",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io-client": "^4.8.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2"
  }
