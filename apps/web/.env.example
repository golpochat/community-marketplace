NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
INTERNAL_API_URL=http://localhost:4000
REVALIDATE_SECRET=dev-revalidate-secret-change-in-production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# SEO / analytics (optional — set in production)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=sellnearby.ie

# OTP pilot — phone codes are log-only until Twilio (or similar) is wired
NEXT_PUBLIC_OTP_PILOT_MODE=true

# Closed pilot — Google Form link shown on /contact (see docs/runbooks/pilot-feedback.md)
# NEXT_PUBLIC_PILOT_FEEDBACK_FORM_URL=https://docs.google.com/forms/d/e/YOUR_FORM_ID/viewform

# Unified advertising system (deploy-time flags)
NEXT_PUBLIC_ADS_SYSTEM_ENABLED=false
NEXT_PUBLIC_ADS_PREVIEW_MODE=false
