# syntax=docker/dockerfile:1

# ── Community Marketplace Web (Next.js) ──────────────────────────────────────
# Build:  docker build -f infra/docker/Dockerfile.web -t cm-web .
# Run:    docker run -p 3000:3000 -e NEXT_PUBLIC_API_URL=http://api:4000/api cm-web

FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate
WORKDIR /app
ENV CI=true

FROM base AS deps
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY packages/config/package.json ./packages/config/
COPY packages/types/package.json ./packages/types/
COPY packages/utils/package.json ./packages/utils/
COPY packages/validation/package.json ./packages/validation/
COPY packages/ui/package.json ./packages/ui/
COPY packages/ui-dashboard/package.json ./packages/ui-dashboard/
COPY apps/web/package.json ./apps/web/
COPY apps/web/eslint-plugin-design-system ./apps/web/eslint-plugin-design-system
RUN pnpm fetch

FROM base AS builder
COPY --from=deps /app/pnpm-lock.yaml /app/pnpm-workspace.yaml /app/package.json ./
COPY . .
ARG NEXT_PUBLIC_API_URL=http://localhost:4000/api
ARG NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
ARG NEXT_PUBLIC_OTP_PILOT_MODE=true
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=$NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
ENV NEXT_PUBLIC_OTP_PILOT_MODE=$NEXT_PUBLIC_OTP_PILOT_MODE
RUN pnpm install --frozen-lockfile --prefer-offline --ignore-scripts
RUN node apps/web/scripts/clean-pwa-sw.mjs
RUN NODE_ENV=production pnpm --filter "./packages/*" build \
 && NODE_ENV=production pnpm --filter @community-marketplace/web build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000
RUN apk add --no-cache wget \
 && addgroup -S cm && adduser -S cm -G cm
USER cm

COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

EXPOSE 3000
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s \
  CMD wget -qO- http://localhost:3000/ || exit 1
CMD ["node", "apps/web/server.js"]
