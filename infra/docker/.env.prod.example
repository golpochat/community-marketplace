# Copy to .env.prod on the VPS: cp .env.prod.example .env.prod
# Generate secrets: openssl rand -hex 32

DOMAIN=sellnearby.ie
ACME_EMAIL=support@sellnearby.ie

POSTGRES_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME
MEILI_MASTER_KEY=CHANGE_ME
GRAFANA_PASSWORD=CHANGE_ME

# Stripe (live keys when ready — test keys OK for first deploy smoke)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Web checkout (baked into Next.js at docker build — rebuild web after changing)
STRIPE_PUBLISHABLE_KEY=

# Email (Brevo is the default provider — verify EMAIL_FROM in your Brevo account)
BREVO_API_KEY=
EMAIL_FROM=noreply@sellnearby.ie
# Optional fallback provider
SENDGRID_API_KEY=

# Cloudflare R2 (optional for first deploy — local dev uploads fallback)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sellnearby-prod
R2_ENDPOINT=
R2_PUBLIC_URL=

# Production safety (keep false for normal API runs)
RBAC_SEED_ENABLED=false
RBAC_SEED_FORCE=false

# OTP pilot — no SMS provider yet; codes appear in the register UI. Set false after Twilio + rebuild web.
OTP_PILOT_MODE=true

# Super-admin bootstrap — used only by ./infra/scripts/seed-super-admin-prod-docker.sh
# Use your real login email and a strong password. Quote display name if it has spaces.
RBAC_SUPER_ADMIN_EMAIL=admin@sellnearby.ie
RBAC_SUPER_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
RBAC_SUPER_ADMIN_DISPLAY_NAME=Admin
