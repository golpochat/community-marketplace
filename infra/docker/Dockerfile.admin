# syntax=docker/dockerfile:1

# ── Community Marketplace Admin (Next.js) ────────────────────────────────────
# Build:  docker build -f infra/docker/Dockerfile.admin -t cm-admin .
# Run:    docker run -p 3001:3001 -e NEXT_PUBLIC_API_URL=http://api:4000/api cm-admin

FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate
WORKDIR /app
ENV CI=true

FROM base AS deps
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY packages/config/package.json ./packages/config/
COPY packages/types/package.json ./packages/types/
COPY packages/utils/package.json ./packages/utils/
COPY packages/validation/package.json ./packages/validation/
COPY packages/ui/package.json ./packages/ui/
COPY packages/ui-dashboard/package.json ./packages/ui-dashboard/
COPY apps/admin/package.json ./apps/admin/
RUN pnpm fetch

FROM base AS builder
COPY --from=deps /app/pnpm-lock.yaml /app/pnpm-workspace.yaml /app/package.json ./
COPY . .
ARG NEXT_PUBLIC_API_URL=http://localhost:4000/api
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
RUN pnpm install --frozen-lockfile --prefer-offline --ignore-scripts
RUN pnpm --filter "./packages/*" build \
 && pnpm --filter @community-marketplace/admin build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
RUN apk add --no-cache wget \
 && addgroup -S cm && adduser -S cm -G cm
USER cm

COPY --from=builder /app/apps/admin/.next/standalone ./
COPY --from=builder /app/apps/admin/.next/static ./apps/admin/.next/static

EXPOSE 3001
ENV PORT=3001
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s \
  CMD wget -qO- http://localhost:3001/ || exit 1
CMD ["node", "apps/admin/server.js"]
