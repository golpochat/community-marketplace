{
  "name": "@community-marketplace/validation",
  "version": "0.0.0",
  "private": true,
  "description": "Shared validation schemas (Zod)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./search": {
      "types": "./src/search.schema.ts",
      "import": "./src/search.schema.ts",
      "require": "./dist/search.schema.js",
      "default": "./src/search.schema.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"lint: validation\"",
    "prepare": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@community-marketplace/config": "workspace:*",
    "@community-marketplace/types": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
