{
  "name": "@community-marketplace/ui-dashboard",
  "version": "0.0.0",
  "private": true,
  "description": "Shared role-based dashboard shell components",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./themes.css": "./src/styles/themes.css",
    "./sidebar-config": {
      "types": "./src/lib/sidebar-config.ts",
      "import": "./src/lib/sidebar-config.ts",
      "default": "./src/lib/sidebar-config.ts"
    },
    "./theme": {
      "types": "./src/lib/theme.ts",
      "import": "./src/lib/theme.ts",
      "default": "./src/lib/theme.ts"
    },
    "./layouts/DashboardLayout": {
      "types": "./src/layouts/DashboardLayout.tsx",
      "import": "./src/layouts/DashboardLayout.tsx",
      "default": "./src/layouts/DashboardLayout.tsx"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"lint: ui-dashboard\""
  },
  "peerDependencies": {
    "next": "^15.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@community-marketplace/types": "workspace:*",
    "@community-marketplace/ui": "workspace:*",
    "lucide-react": "^0.469.0"
  },
  "devDependencies": {
    "@community-marketplace/config": "workspace:*",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
