{
  "name": "@community-marketplace/utils",
  "version": "0.0.0",
  "private": true,
  "description": "Shared utility functions",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"lint: utils\""
  },
  "dependencies": {
    "@community-marketplace/types": "workspace:*"
  },
  "devDependencies": {
    "@community-marketplace/config": "workspace:*",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
