{
  "name": "@community-marketplace/config",
  "version": "0.0.0",
  "private": true,
  "description": "Shared configuration, constants, and environment loaders",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./constants": {
      "types": "./src/constants.ts",
      "import": "./src/constants.ts",
      "require": "./dist/constants.js",
      "default": "./src/constants.ts"
    },
    "./env": {
      "types": "./src/env.ts",
      "import": "./src/env.ts",
      "require": "./dist/env.js",
      "default": "./src/env.ts"
    },
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./tsconfig.node.json": "./tsconfig.node.json",
    "./tsconfig.react.json": "./tsconfig.react.json"
  },
  "files": [
    "dist",
    "src",
    "tsconfig.base.json",
    "tsconfig.node.json",
    "tsconfig.react.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"lint: config\""
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
